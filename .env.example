# Required: API key for the configured provider.
AI_ASSISTANT_API_KEY=sk-your-key

# Provider and model. Leave AI_ASSISTANT_MODEL empty to use the starter default for the provider.
AI_ASSISTANT_PROVIDER=openai
AI_ASSISTANT_BASE_URL=
AI_ASSISTANT_MODEL=
AI_ASSISTANT_CONTEXT_PATH=/ai-assistant

# Host port exposed by docker compose.
AI_ASSISTANT_PORT=8080

# Optional service protection. Set this in production and pass X-AI-Token from clients.
AI_ASSISTANT_ACCESS_TOKEN=

# Comma-separated allowed browser origins. Use explicit origins in production.
AI_ASSISTANT_ALLOWED_ORIGINS=*

# Per-client requests per minute. 0 disables in-process rate limiting.
AI_ASSISTANT_RATE_LIMIT=60

# Model request tuning.
AI_ASSISTANT_TIMEOUT_SECONDS=60
AI_ASSISTANT_MAX_TOKENS=2048
AI_ASSISTANT_TEMPERATURE=0.7
AI_ASSISTANT_LLM_MAX_RETRIES=2
AI_ASSISTANT_ALLOWED_MODELS=
AI_ASSISTANT_SYSTEM_PROMPT=
AI_ASSISTANT_ALLOW_CLIENT_SYSTEM_PROMPT=true
AI_ASSISTANT_CLIENT_SYSTEM_PROMPT_MAX_CHARS=4000

# Optional feature switches.
AI_ASSISTANT_ALLOW_QUERY_TOKEN_AUTH=false
AI_ASSISTANT_WEBSOCKET_ENABLED=false
AI_ASSISTANT_ADMIN_ENABLED=false
AI_ASSISTANT_CONNECTOR_MANAGEMENT_ENABLED=false
AI_ASSISTANT_MCP_SERVER_ENABLED=false
AI_ASSISTANT_RAG_ENABLED=false
AI_ASSISTANT_EMBEDDING_MODEL=
AI_ASSISTANT_EMBEDDING_DIMENSIONS=1536
AI_ASSISTANT_PII_MASKING_ENABLED=true
AI_ASSISTANT_HEADLESS_FETCH_ENABLED=false
AI_ASSISTANT_HEADLESS_FETCH_TIMEOUT_SECONDS=30
AI_ASSISTANT_URL_FETCH_ENABLED=true
AI_ASSISTANT_URL_FETCH_SSRF_PROTECTION=true
AI_ASSISTANT_URL_FETCH_MAX_BYTES=524288
AI_ASSISTANT_URL_FETCH_TIMEOUT_SECONDS=15
AI_ASSISTANT_URL_FETCH_MAX_CHARS_INJECTED=24000
AI_ASSISTANT_URL_FETCH_CACHE_TTL_SECONDS=90
AI_ASSISTANT_URL_FETCH_CACHE_MAX_ENTRIES=32
AI_ASSISTANT_URL_PREVIEW_MAX_SUMMARY_CHARS=900
AI_ASSISTANT_URL_PREVIEW_MAX_IMAGES=10

# Upload, document extraction, and export limits.
AI_ASSISTANT_MULTIPART_MAX_FILE_SIZE=10MB
AI_ASSISTANT_MULTIPART_MAX_REQUEST_SIZE=10MB
AI_ASSISTANT_FILE_MAX_EXTRACTED_CHARS=300000
AI_ASSISTANT_EXPORT_MAX_MESSAGES=2000
AI_ASSISTANT_EXPORT_MAX_TOTAL_CHARS=2000000
AI_ASSISTANT_EXPORT_MAX_IMAGE_BYTES=3000000
AI_ASSISTANT_EXPORT_MAX_IMAGE_URLS=64
AI_ASSISTANT_EXPORT_EMBED_IMAGES=true
AI_ASSISTANT_CHAT_MAX_TOTAL_CHARS=300000
AI_ASSISTANT_CHAT_HISTORY_MAX_CHARS=48000

# Optional JVM tuning for the standalone container.
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:+UseStringDeduplication

# Optional: Docker build-time proxy for pulling base images and Maven dependencies.
# On Docker Desktop, use host.docker.internal to reach a proxy running on the Windows host.
# DOCKER_BUILD_HTTP_PROXY=http://host.docker.internal:7897
# DOCKER_BUILD_HTTPS_PROXY=http://host.docker.internal:7897
# DOCKER_BUILD_NO_PROXY=localhost,127.0.0.1,host.docker.internal
# DOCKER_BUILD_MAVEN_OPTS=-Dhttp.proxyHost=host.docker.internal -Dhttp.proxyPort=7897 -Dhttps.proxyHost=host.docker.internal -Dhttps.proxyPort=7897
