# Point the playground to the standalone Docker service.
# Leave VITE_AI_ASSISTANT_BASE_URL empty to use the Vite dev proxy at /ai-assistant.
VITE_AI_ASSISTANT_BASE_URL=

# Must match AI_ASSISTANT_ACCESS_TOKEN in the standalone service .env when auth is enabled.
VITE_AI_ASSISTANT_ACCESS_TOKEN=change-me

# Backend origin used by the Vite dev proxy. Change this when port 8080 is occupied.
VITE_AI_ASSISTANT_PROXY_TARGET=http://localhost:8080
